# ============================================================================
# Ultra Content Machine — Environment Configuration
# Copy this file to .env.local and fill in your real API keys
# ============================================================================

# ── fal.ai Image Generation ─────────────────────────────────────────────────
# Primary model: fal-ai/flux-pro/v1.1 (best quality)
# Fallback: fal-ai/flux/dev
# Get key: https://fal.ai/dashboard/keys
FAL_KEY=your_fal_key_here
FAL_MODEL=fal-ai/flux-pro/v1.1

# ── GitHub API ─────────────────────────────────────────────────────────────
# Used for fetching trending repositories
# Get token: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# ── Ollama Pro / AI Content Backend ──────────────────────────────────────────
# Used for generating Hebrew blog content
# Get key: https://ollama.com/settings
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_MODEL=kimi-k2.5

# ── Cloudflare Workers AI ──────────────────────────────────────────────────
# Fallback image generation and LLM
# Get from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# ── Pipeline Configuration ─────────────────────────────────────────────────
# Number of posts to generate per run (default: 3)
POSTS_PER_DAY=3

# ── Sales Agent Chat ─────────────────────────────────────────────────────────
NEXT_PUBLIC_AGENT_URL=https://agent.elyasharlabs.com/chat

# ── Telegram Notifications (optional) ────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Development Flags ────────────────────────────────────────────────────────
# SKIP_FAL_AI=true    # Use Pollinations fallback instead of fal.ai
