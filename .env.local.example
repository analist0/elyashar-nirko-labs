# ============================================================================
# Ultra Content Machine — Environment Configuration
# Copy this file to .env.local and fill in your real API keys
# ============================================================================

# ── fal.ai Image Generation ─────────────────────────────────────────────────
# Primary model: fal-ai/flux-pro/v1.1 (best quality)
# Fallback: fal-ai/flux/dev
# Get key: https://fal.ai/dashboard/keys
FAL_KEY=your_fal_key_here
FAL_MODEL=fal-ai/flux-pro/v1.1

# ── GitHub API ─────────────────────────────────────────────────────────────
# Used for fetching trending repositories
# Get token: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# ── Ollama Pro / AI Content Backend ──────────────────────────────────────────
# Used for generating Hebrew blog content
# Get key: https://ollama.com/settings
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_MODEL=kimi-k2.5

# ── Cloudflare Workers AI ──────────────────────────────────────────────────
# Fallback image generation and LLM
# Get from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# ── Pipeline Configuration ─────────────────────────────────────────────────
# Number of posts to generate per run (default: 3)
POSTS_PER_DAY=3

# ── Sales Agent Chat ─────────────────────────────────────────────────────────
NEXT_PUBLIC_AGENT_URL=https://agent.elyasharlabs.com/chat

# ── Telegram Notifications (optional) ────────────────────────────────────────
# Used by /chat, /lead, and the site chat widget (/widget-message). These
# tokens must ONLY live here (server-side) — never in frontend code, which
# ships as plain text to every visitor's browser.
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id
#
# To notify multiple bots/owners (e.g. two partners), set TELEGRAM_RECIPIENTS
# instead — a JSON array, takes priority over the single token/chat-id pair
# above. `id` is optional and lets the contact form / chat widget target one
# specific partner (ContactSection.tsx sends "joseph" | "michael" | "both"):
# TELEGRAM_RECIPIENTS=[{"token":"111:aaa","chatId":"111","id":"joseph","name":"Joseph"},{"token":"222:bbb","chatId":"222","id":"michael","name":"Michael"}]

# ── Admin CMS (api/server.js) ─────────────────────────────────────────────────
# Required in production — the API refuses to start with NODE_ENV=production
# unless both are set (no insecure "admin"/"admin123" fallback in prod).
ADMIN_USER=your_admin_username
ADMIN_PASS=your_strong_admin_password

# ── Development Flags ────────────────────────────────────────────────────────
# SKIP_FAL_AI=true    # Use Pollinations fallback instead of fal.ai
