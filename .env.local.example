# fal.ai — Primary image generation (FLUX.1 Dev/Schnell)
# Get from: https://fal.ai/dashboard/keys
FAL_KEY=your_fal_key_here

# Cloudflare Workers AI — Fallback image generation + LLM
# Get from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# Ollama Pro Cloud API — Content generation ($20/mo)
# Get from: https://ollama.com/settings
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_MODEL=kimi-k2.5

# GitHub Token for API rate limits
# GITHUB_TOKEN=your_github_token_here

# Sales Agent Backend URL
NEXT_PUBLIC_AGENT_URL=https://agent.elyasharlabs.com/chat

# Telegram Bot (for lead notifications)
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id
